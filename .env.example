# Yerel modeller: her görev için model/<görev>/ altına bir .gguf koyun.
# Dizin içindeki ilk .gguf otomatik yüklenir; ileride ayrı model kolaylıkla değiştirilir.
LLM_BACKEND=auto
DEFAULT_LLM_MODEL=qwen2.5-3b-instruct-q4_k_m.gguf

MAIN_RESPONSER_MODEL_PATH=./model/main_responser/
DATA_CLEANER_MODEL_PATH=./model/data_cleaner/
EXTRACTOR_MODEL_PATH=./model/extractor/
CLASSIFIER_MODEL_PATH=./model/classifier/
EMBEDDER_MODEL_PATH=./model/embedder/
COMPARISON_MODEL_PATH=./model/comparison/

# Veritabanı Yapılandırması (PostgreSQL)
DB_HOST=localhost
DB_PORT=5433
DB_USER=katilim_user
DB_PASSWORD=katilim_password
DB_NAME=katilim_db
DATABASE_URL=postgresql://katilim_user:katilim_password@localhost:5433/katilim_db
