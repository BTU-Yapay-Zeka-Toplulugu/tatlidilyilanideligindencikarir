# Frontend → Backend bağlantı ayarları (Vite build zamanında gömülür)
# Backend'in çalıştığı adres (uvicorn varsayılan: http://localhost:8000)
VITE_API_BASE_URL=http://localhost:8000
# Chatbot streaming WebSocket adresi
VITE_CHATBOT_WS_URL=ws://localhost:8000/ws/chat
# İstek zaman aşımı (ms)
VITE_APP_TIMEOUT=15000
